function syncOperations(ops){var lock=LockService.getScriptLock();lock.waitLock(30000);try{return ops.map(rdrApplyOperation_);}finally{lock.releaseLock();}}
function rdrProcessed_(op){var hit=rdrFind_('ProcessedOps','op_id',op.op_id);return hit?JSON.parse(hit.record.result_json):null;}
function rdrApplyOperation_(op){var old=rdrProcessed_(op);if(old)return old;try{rdrValidateOp_(op);var sheet=RDR_COLLECTIONS[op.entity],idKey=RDR_IDS[op.entity],rec=op.payload||{},id=rec[idKey],hit=id?rdrFind_(sheet,idKey,id):null;if(hit&&op.base_version!==undefined&&Number(hit.record.version)!==Number(op.base_version)){var conflict={op_id:op.op_id,conflict:true,current:hit.record};rdrStoreProcessed_(op,conflict);return conflict;}var now=rdrNow_();if(op.action==='archive'||op.action==='restore'){if(!hit)throw new Error('Record not found.');rec=hit.record;rec.status=op.action==='archive'?'archived':'active';}else if(hit){rec=Object.assign({},hit.record,rec);}else{if(!id){id=rdrId_(op.entity==='item'?'ITEM':op.entity==='commitment'?'COM':op.entity==='task'?'TASK':op.entity==='trip_leg'?'LEG':op.entity==='leg_crew'?'LC':op.entity==='link'?'LINK':'PCHK');rec[idKey]=id;}}rec.updated_at=now;rec.version=(Number(hit&&hit.record.version)||0)+1;if(op.entity==='item')rdrEnsureEachCrewChecks_(rec,op.actor_person_id);if(hit)rdrWrite_(hit,rec);else rdrAppend_(sheet,rec);var result={op_id:op.op_id,record:rec};rdrActivity_(op,rec);rdrStoreProcessed_(op,result);return result;}catch(e){var failure={op_id:op&&op.op_id,error:e.message};if(op&&op.op_id)rdrStoreProcessed_(op,failure);return failure;}}
function rdrStoreProcessed_(op,result){rdrAppend_('ProcessedOps',{op_id:op.op_id,device_id:op.device_id,received_at:rdrNow_(),result_json:JSON.stringify(result)});}
function rdrActivity_(op,rec){var idKey=RDR_IDS[op.entity],summary=op.action+' '+op.entity;rdrAppend_('Activity',{activity_id:rdrId_('ACT'),op_id:op.op_id,person_id:op.actor_person_id,crew_id:rec.crew_id||'',entity_type:op.entity,entity_id:rec[idKey],action:op.action,summary:summary,created_at:rdrNow_(),device_id:op.device_id});}

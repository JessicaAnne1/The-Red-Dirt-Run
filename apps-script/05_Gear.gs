function rdrEnsureEachCrewChecks_(item,actor){if(item.scope!=='each_crew')return;rdrRead_('Crews').filter(function(c){return String(c.active)!=='false';}).forEach(function(c){var has=rdrRead_('PersonalChecks').some(function(x){return x.item_id===item.item_id&&x.crew_id===c.crew_id;});if(!has)rdrAppend_('PersonalChecks',{personal_check_id:rdrId_('PCHK'),item_id:item.item_id,crew_id:c.crew_id,qty:1,state:'unclaimed',notes:'',updated_by:actor,updated_at:rdrNow_(),version:1});});}
function repairSeedPersonalChecks(){var sh=rdrSheet_().getSheetByName('PersonalChecks'),values=sh.getDataRange().getValues(),heads=values.shift(),stateCol=heads.indexOf('state'),notesCol=heads.indexOf('notes');var changed=0;values.forEach(function(row,i){if(String(row[stateCol])==='claimed'&&!String(row[notesCol]||'')){row[stateCol]='unclaimed';changed++;sh.getRange(i+2,stateCol+1).setValue('unclaimed');}});return 'Reset '+changed+' blank seed checks to unclaimed.';}

function doGet(){return rdrJson_({ok:true,app:'The Red Dirt Run'});}function doPost(e){try{var req=JSON.parse(e.postData.contents||'{}');if(req.action==='bootstrap')return rdrJson_(rdrBootstrap_());if(req.action==='syncOperations')return rdrJson_({results:syncOperations(req.operations||[])});if(req.action==='getArchive')return rdrJson_(rdrArchive_());return rdrJson_({error:'Unknown action'});}catch(err){return rdrJson_({error:err.message});}}

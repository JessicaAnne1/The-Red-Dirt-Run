function rdrRead_(name){var sh=rdrSheet_().getSheetByName(name),v=sh.getDataRange().getValues(),h=v.shift(),tz=rdrSheet_().getSpreadsheetTimeZone();return v.filter(function(r){return r.some(String);}).map(function(r){var o={};h.forEach(function(k,i){var value=r[i];if(value instanceof Date&&(k==='date'||k==='due_date'||(name==='Config'&&k==='value'&&String(r[0])==='departure_date')))value=Utilities.formatDate(value,tz,'yyyy-MM-dd');o[k]=value;});return o;});}
function rdrAppend_(name,rec){var h=RDR_SHEETS[name];rdrSheet_().getSheetByName(name).appendRow(h.map(function(k){return rec[k]===undefined?'':rec[k];}));}
function rdrFind_(name,idKey,id){var sh=rdrSheet_().getSheetByName(name),all=sh.getDataRange().getValues(),head=all[0],col=head.indexOf(idKey);for(var r=1;r<all.length;r++)if(String(all[r][col])===String(id))return {sheet:sh,row:r+1,head:head,record:rdrRead_(name)[r-1]};return null;}
function rdrWrite_(hit,rec){hit.sheet.getRange(hit.row,1,1,hit.head.length).setValues([hit.head.map(function(k){return rec[k]===undefined?'':rec[k];})]);}
function rdrBootstrap_(){var all={config:rdrRead_('Config'),crews:rdrRead_('Crews'),people:rdrRead_('People'),items:rdrRead_('Items'),personalChecks:rdrRead_('PersonalChecks'),commitments:rdrRead_('Commitments').filter(function(x){return x.status!=='archived';}),tasks:rdrRead_('Tasks').filter(function(x){return x.status!=='archived';}),tripLegs:rdrRead_('TripLegs').filter(function(x){return x.status!=='archived';}),legCrews:rdrRead_('LegCrews').filter(function(x){return x.status!=='archived';}),links:rdrRead_('Links').filter(function(x){return x.status!=='archived';}),activity:rdrRead_('Activity').slice(-50).reverse()};return all;}
function rdrArchive_(){return {items:rdrRead_('Items').filter(function(x){return x.status==='archived';}),tasks:rdrRead_('Tasks').filter(function(x){return x.status==='archived';})};}

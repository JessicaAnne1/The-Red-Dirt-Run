function rdrValidActor_(personId){return !!rdrRead_('People').filter(function(p){return p.person_id===personId&&String(p.active)!=='false';})[0];}
function rdrValidateOp_(op){if(!op||!op.op_id||!op.entity||!op.action||!op.actor_person_id||!op.device_id)throw new Error('Invalid operation envelope.');if(!RDR_COLLECTIONS[op.entity])throw new Error('Unsupported entity.');if(!rdrValidActor_(op.actor_person_id))throw new Error('Unknown actor.');var p=op.payload||{};if(p.scope&&['each_crew','communal'].indexOf(p.scope)<0)throw new Error('Invalid scope.');if(p.state&&['claimed','packed','loaded'].indexOf(p.state)<0)throw new Error('Invalid state.');}

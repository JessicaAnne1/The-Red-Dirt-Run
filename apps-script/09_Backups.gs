function runBackup(){var ss=rdrSheet_(),name='Backup '+Utilities.formatDate(new Date(),ss.getSpreadsheetTimeZone(),'yyyy-MM-dd HHmm');var copy=ss.copy(name);return 'Created backup: '+copy.getUrl();}
function rdrDeleteWhere_(sheetName,key,values){var sh=rdrSheet_().getSheetByName(sheetName),all=sh.getDataRange().getValues(),col=all[0].indexOf(key);for(var r=all.length-1;r>0;r--)if(values.indexOf(String(all[r][col]))>=0)sh.deleteRow(r+1);}
function cleanupLegacySmokeRecords(){var commitments=rdrRead_('Commitments').filter(function(x){return String(x.item_id)==='ITEM-SMOKE';}).map(function(x){return String(x.commitment_id);});rdrDeleteWhere_('Commitments','commitment_id',commitments);rdrDeleteWhere_('Items','item_id',['ITEM-SMOKE']);return 'Removed ITEM-SMOKE and '+commitments.length+' associated commitments.';}
function runSmokeTests(){setupWorkbook();var tag=Utilities.getUuid().slice(0,8),itemId='ITEM-SMOKE-'+tag,oneId='COM-SMOKE-A-'+tag,twoId='COM-SMOKE-B-'+tag,device='smoke-'+tag,ops=[];try{var base={op_id:device+'-item',entity:'item',action:'create',actor_person_id:'P-JESSICA',device_id:device,payload:{item_id:itemId,name:'Smoke item',category:'Camp kitchen',scope:'communal',source:'custom',qty_needed:3,unit:'items',status:'active'}};var a=syncOperations([base,base,base]);if(a.filter(function(x){return x.record;}).length!==3||rdrRead_('Items').filter(function(x){return x.item_id===itemId;}).length!==1)throw new Error('Idempotency failed');var one=syncOperations([{op_id:device+'-a',entity:'commitment',action:'create',actor_person_id:'P-JESSICA',device_id:device,payload:{commitment_id:oneId,item_id:itemId,crew_id:'C-JESSICA-MICHAEL',qty:2,state:'claimed',status:'active}}])[0];var two=syncOperations([{op_id:device+'-b',entity:'commitment',action:'create',actor_person_id:'P-TAYA',device_id:device,payload:{commitment_id:twoId,item_id:itemId,crew_id:'C-TAYA-SIMON',qty:1,state:'claimed',status:'active}}])[0];if(!one.record||!two.record)throw new Error('Communal contribution failed');var stale=syncOperations([{op_id:device+'-conflict',entity:'item',action:'update',actor_person_id:'P-JESSICA',device_id:device,base_version:0,payload:{item_id:itemId,name:'Stale'}}])[0];if(!stale.conflict)throw new Error('Conflict handling failed');return 'Smoke tests passed and will be cleaned up.';}finally{rdrDeleteWhere_('Commitments','commitment_id',[oneId,twoId]);rdrDeleteWhere_('Items','item_id',[itemId]);rdrDeleteWhere_('ProcessedOps','device_id',[device]);}}
